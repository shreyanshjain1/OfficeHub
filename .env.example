APP_ENV=local
APP_NAME="Office Request Hub"
APP_BASE_URL=http://localhost
APP_SECRET=change_this_to_a_long_random_string

DB_HOST=127.0.0.1
DB_NAME=office_request_hub
DB_USER=office_user
DB_PASS=office_pass
DB_PORT=3306

# Uploads directory (ABSOLUTE path recommended on cPanel, outside web root)
UPLOAD_DIR=/var/www/office-request-hub-storage/uploads

# Cookie/security
COOKIE_SECURE=0
COOKIE_SAMESITE=Lax
SESSION_TTL_MINUTES=240
